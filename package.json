{
  "name": "bifa-web-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && sudo cp -r dist/* /var/www/bifa/ && sudo nginx -s reload"
  },
  "dependencies": {
    "three": "0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "^4.1.4"
  }
}
